@page "/counter"
@using BlazorLiveView.Core.JSInterop

@inject ILiveViewJSRuntime LiveViewJS

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;

        if (currentCount % 5 == 0)
        {
            if (currentCount % 10 == 0)
            {
                _ = LiveViewJS.InvokeVoidAsyncNoMirror("alert", $"Current count is {currentCount}");
            }
            else
            {
                _ = LiveViewJS.InvokeVoidAsync("alert", $"Current count is {currentCount}");
            }
        }
    }
}
