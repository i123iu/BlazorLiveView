@page "/performance"
@implements IDisposable

<h3>Performance Test</h3>

<div class="performance-test">
    <div class="controls">
        <div class="control-group">
            <strong>Redrawing:</strong>
            <button class="btn btn-primary" @onclick="StartRedrawing" disabled="@isRunning">Start</button>
            <button class="btn btn-secondary" @onclick="StopRedrawing" disabled="@(!isRunning)">Stop</button>
        </div>
        <div class="control-group">
            <strong>Measuring:</strong>
            <button class="btn btn-success" @onclick="StartMeasuring" disabled="@isMeasuring">Start</button>
            <button class="btn btn-warning" @onclick="StopMeasuring" disabled="@(!isMeasuring)">Stop</button>
            <button class="btn btn-danger" @onclick="RestartMeasuring">Restart</button>
            <label class="ms-3">
                Test Duration (seconds):
                <input type="number" @bind="testDuration" @bind:event="oninput" min="1" max="60" style="width: 80px;" disabled="@isMeasuring" />
            </label>
        </div>
    </div>

    <div class="metrics mt-3">
        <div class="metric-card">
            <h5>Update Count</h5>
            <div class="metric-value">@updateCount</div>
        </div>
        <div class="metric-card">
            <h5>Elapsed Time</h5>
            <div class="metric-value">@elapsedSeconds.ToString("F2")s</div>
        </div>
        <div class="metric-card">
            <h5>Updates/Second</h5>
            <div class="metric-value">@updatesPerSecond.ToString("F1")</div>
        </div>
        <div class="metric-card">
            <h5>Random Value</h5>
            <div class="metric-value">@randomValue</div>
        </div>
    </div>

    <div class="render-area mt-4">
        <h5>Rapidly Changing UI Elements</h5>
        <div class="boxes">
            @for (int i = 0; i < 128; i++)
            {
                var index = i;
                <div class="box" style="background-color: hsl(@((randomValue + index * 7) % 360), 70%, 60%);">
                    @((randomValue + index) % 100)
                </div>
            }
        </div>
    </div>
</div>

<style>
    .performance-test {
        padding: 20px;
    }

    .controls {
        display: flex;
        flex-direction: column;
        gap: 15px;
    }

    .control-group {
        display: flex;
        align-items: center;
        gap: 10px;
    }

        .control-group strong {
            min-width: 90px;
        }

    .metrics {
        display: flex;
        gap: 15px;
        flex-wrap: wrap;
    }

    .metric-card {
        background: #f8f9fa;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 15px;
        min-width: 150px;
    }

        .metric-card h5 {
            margin: 0 0 10px 0;
            font-size: 0.9rem;
            color: #6c757d;
        }

    .metric-value {
        font-size: 1.5rem;
        font-weight: bold;
        color: #212529;
    }

    .render-area {
        background: #ffffff;
        border: 1px solid #dee2e6;
        border-radius: 8px;
        padding: 20px;
    }

    .boxes {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(60px, 1fr));
        gap: 10px;
        margin-top: 15px;
    }

    .box {
        aspect-ratio: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        font-weight: bold;
        color: white;
        text-shadow: 1px 1px 2px rgba(0,0,0,0.3);
    }
</style>

@code {
    private bool isRunning = false;
    private bool isMeasuring = false;
    private int updateCount = 0;
    private int randomValue = 0;
    private int testDuration = 5;
    private DateTime startTime;
    private double elapsedSeconds = 0;
    private double updatesPerSecond = 0;
    private Random random = new Random();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        await base.OnAfterRenderAsync(firstRender);

        if (!isRunning) return;

        randomValue = random.Next(0, 1000);

        if (isMeasuring)
        {
            var elapsed = (DateTime.Now - startTime).TotalSeconds;
            if (elapsed >= testDuration)
            {
                isMeasuring = false;
                StateHasChanged();
                return;
            }

            updateCount++;
            elapsedSeconds = elapsed;
            updatesPerSecond = elapsedSeconds > 0 ? updateCount / elapsedSeconds : 0;
        }

        StateHasChanged();
    }

    private void StartRedrawing()
    {
        isRunning = true;
        StateHasChanged();
    }

    private void StopRedrawing()
    {
        isRunning = false;
    }

    private void StartMeasuring()
    {
        isMeasuring = true;
        updateCount = 0;
        elapsedSeconds = 0;
        updatesPerSecond = 0;
        startTime = DateTime.Now;
    }

    private void StopMeasuring()
    {
        isMeasuring = false;
    }

    private void RestartMeasuring()
    {
        StopMeasuring();
        StartMeasuring();
    }

    public void Dispose()
    {
        isRunning = false;
        isMeasuring = false;
    }
}
