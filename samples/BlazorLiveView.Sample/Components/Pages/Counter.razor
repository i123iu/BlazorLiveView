@page "/counter"
@using BlazorLiveView.Core.Circuits.Services

@inject ILiveViewJSRuntime LiveViewJS

<PageTitle>Counter</PageTitle>

<h1>Counter</h1>

<p role="status" @ref="x">Current count: @currentCount</p>

<button class="btn btn-primary" @onclick="IncrementCount">Click me</button>

@code {
    private ElementReference x;

    private int currentCount = 0;

    private void IncrementCount()
    {
        currentCount++;

        if(currentCount % 5 == 0)
        {
            LiveViewJS.InvokeVoidAsync("alert", $"Current count is {currentCount}");
        }
    }
}
