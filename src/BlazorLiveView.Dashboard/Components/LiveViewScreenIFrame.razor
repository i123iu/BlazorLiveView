@using BlazorLiveView.Core.Circuits.Services
@using BlazorLiveView.Core.Components.Tools

@implements IDisposable

@inject ILiveViewMirrorUriBuilder MirrorUriBuilder
@inject ICircuitTracker CircuitTracker

<iframe class="liveview-screen-iframe"
        @key="@_state"
        src="@MirrorUriBuilder.GetPathAndQuery(MirrorUri)"
        width="@(IframeSize is null ? "100%" : IframeSize.Value.x + "px")"
        height="@(IframeSize is null ? "100%" : IframeSize.Value.y + "px")" />

@code {
    [Parameter]
    [EditorRequired]
    public string SourceCircuitId { get; set; } = default!;

    [Parameter]
    public Position? WindowSize { get; set; } = null;

    [Parameter]
    public bool DebugView { get; set; } = false;

    [Parameter]
    public EventCallback<IMirrorCircuit?> MirrorCircuitChanged { get; set; }

    private MirrorUri MirrorUri => new(SourceCircuitId, _state, DebugView);
    private Position? IframeSize => WindowSize is null ? null
    : (WindowSize.Value + new Position(4, 4)); // For red border width

    public IMirrorCircuit? MirrorCircuit { get; private set; }

    private Guid _state = Guid.NewGuid();

    protected override void OnInitialized()
    {
        CircuitTracker.OnCircuitOpened += OnCircuitOpened;
        base.OnInitialized();
    }

    public void Dispose()
    {
        CircuitTracker.OnCircuitOpened -= OnCircuitOpened;
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        //ResetState();
        StateHasChanged();
    }

    private void OnCircuitOpened(ICircuit circuit)
    {
        if (circuit is not IMirrorCircuit mirrorCircuit)
            return;
        if (mirrorCircuit.State == _state)
        {
            MirrorCircuit = mirrorCircuit;
            InvokeAsync(() => MirrorCircuitChanged.InvokeAsync(mirrorCircuit));
        }
    }

    public void ResetState()
    {
        _state = Guid.NewGuid();
        MirrorCircuit = null;
        MirrorCircuitChanged.InvokeAsync(null);
        StateHasChanged();
    }
}
