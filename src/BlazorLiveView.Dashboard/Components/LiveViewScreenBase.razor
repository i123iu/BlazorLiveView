@using BlazorLiveView.Core.Circuits
@using BlazorLiveView.Core.Circuits.Services
@using BlazorLiveView.Dashboard.Models
@using Microsoft.Extensions.Logging

@inject ICircuitTracker CircuitTracker
@inject IPausedCircuitsTracker PausedCircuitsTracker
@inject ILogger<LiveViewScreenBase> Logger

@implements IDisposable

@code {
    protected LiveViewScreenIFrame? liveViewScreenIFrame;
    protected HashSet<string> subscribedCircuitIds = new();

    protected bool IsSyncScreenSizeActive { get; set; } = false;
    protected bool IsSyncScrollPositionActive { get; set; } = false;
    protected bool IsPointerActive { get; set; } = false;

    private PausedSessionReference? _pausedSessionReference;
    protected PausedSessionReference? PausedSessionReference
    {
        get => _pausedSessionReference;
        set {
            if (_pausedSessionReference == value) return;
            if (_pausedSessionReference is not null)
            {
                _pausedSessionReference.Unpaused -= OnPausedCircuitUnpaused;
                _pausedSessionReference.UnmarkPaused();
                _pausedSessionReference = null;
            }
            if (value is not null)
            {
                _pausedSessionReference = value;
                _pausedSessionReference.Unpaused += OnPausedCircuitUnpaused;
            }
        }
    }

    private IUserCircuit? _sourceCircuit;
    protected IUserCircuit? SourceCircuit
    {
        get => _sourceCircuit;
        set
        {
            if (_sourceCircuit == value) return;

            PausedSessionReference = null;

            _sourceCircuit = value;
            if (_sourceCircuit is null) return;

            _sourceCircuit.SessionIdAssigned += OnSourceCircuitSessionIdAssigned;
            if (_sourceCircuit.SessionId is not null)
            {
                OnSourceCircuitSessionIdAssigned(_sourceCircuit);
            }

            liveViewScreenIFrame?.ResetState();
            StateHasChanged();
        }
    }

    protected IMirrorCircuit? MirrorCircuit
        => liveViewScreenIFrame?.MirrorCircuit;

    protected LiveViewRenderState GetRenderState()
    {
        if (SourceCircuit is null)
            return LiveViewRenderState.SourceCircuitNotFound;
        else if (SourceCircuit.CircuitStatus == CircuitStatus.Closed)
            return LiveViewRenderState.SourceCircuitClosed;
        else if (MirrorCircuit is null)
            return LiveViewRenderState.MirrorCircuitLoading;
        else if (MirrorCircuit.IsBlocked)
            return LiveViewRenderState.MirrorCircuitBlocked;
        else if (MirrorCircuit.CircuitStatus == CircuitStatus.Closed)
            return LiveViewRenderState.MirrorCircuitClosed;

        return LiveViewRenderState.Working;
    }

    protected override void OnInitialized()
    {
        CircuitTracker.OnCircuitOpened += OnAnyCircuitOpened;
        CircuitTracker.OnCircuitClosed += OnAnyCircuitClosed;
    }

    public virtual void Dispose()
    {
        CircuitTracker.OnCircuitOpened -= OnAnyCircuitOpened;
        CircuitTracker.OnCircuitClosed -= OnAnyCircuitClosed;

        foreach (var circuitId in subscribedCircuitIds.ToList())
        {
            var circuit = CircuitTracker.GetCircuit(circuitId);
            if (circuit is not null)
            {
                UnsubscribeFromCircuit(circuit);
            }
        }

        PausedSessionReference = null;
    }

    protected void SubscribeToCircuit(ICircuit circuit)
    {
        if (circuit is IUserCircuit userCircuit &&
            subscribedCircuitIds.Add(circuit.Id))
        {
            userCircuit.UriChanged += OnAnyUserCircuitChanged;
            userCircuit.AuthenticationStateChanged += OnAnyUserCircuitChanged;
            userCircuit.CircuitStatusChanged += OnAnyCircuitChanged;
            userCircuit.WindowResized += OnAnyCircuitWindowResized;
        }
    }

    protected void UnsubscribeFromCircuit(ICircuit circuit)
    {
        if (circuit is IUserCircuit userCircuit &&
            subscribedCircuitIds.Remove(circuit.Id))
        {
            userCircuit.UriChanged -= OnAnyUserCircuitChanged;
            userCircuit.AuthenticationStateChanged -= OnAnyUserCircuitChanged;
            userCircuit.CircuitStatusChanged -= OnAnyCircuitChanged;
            userCircuit.WindowResized -= OnAnyCircuitWindowResized;
        }
    }

    protected void MirrorCircuitChanged(IMirrorCircuit mirrorCircuit)
    {
        mirrorCircuit?.NotifyScrollSyncChanged(IsSyncScrollPositionActive);
        StateHasChanged();
    }

    protected void OnAnyCircuitChanged(ICircuit _)
    {
        InvokeAsync(StateHasChanged);
    }

    protected void OnAnyUserCircuitChanged(IUserCircuit _)
    {
        InvokeAsync(StateHasChanged);
    }

    protected void OnAnyCircuitWindowResized(IUserCircuit _)
    {
        if (IsSyncScreenSizeActive)
        {
            InvokeAsync(StateHasChanged);
        }
    }

    protected Task OnIsSyncWindowSizeActiveChanged(bool value)
    {
        IsSyncScreenSizeActive = value;
        MirrorCircuit?.NotifyWindowSizeSyncChanged(IsSyncScreenSizeActive);
        if (!IsSyncScreenSizeActive)
            OnIsSyncScrollPositionActiveChanged(false);
        return Task.CompletedTask;
    }

    protected Task OnIsSyncScrollPositionActiveChanged(bool value)
    {
        IsSyncScrollPositionActive = value;
        MirrorCircuit?.NotifyScrollSyncChanged(IsSyncScrollPositionActive);
        return Task.CompletedTask;
    }

    protected Task OnIsPointerActiveChanged(bool value)
    {
        IsPointerActive = value;
        MirrorCircuit?.NotifyLaserPointerEnabledChanged(IsPointerActive);
        return Task.CompletedTask;
    }

    private void OnSourceCircuitSessionIdAssigned(IUserCircuit userCircuit)
    {
        _sourceCircuit?.SessionIdAssigned -= OnSourceCircuitSessionIdAssigned;
        if (PausedSessionReference is not null &&
            PausedSessionReference.circuitSessionId == userCircuit.SessionId)
            return;
        PausedSessionReference = PausedCircuitsTracker.MarkPaused(
            userCircuit.SessionId!.Value);
    }

    private void OnPausedCircuitUnpaused(PausedSessionReference r)
    {
        if (PausedSessionReference != r) return;
        PausedSessionReference = null;
    }

    protected virtual void OnAnyCircuitOpened(ICircuit circuit)
    {
        // Override in derived components
    }

    protected virtual void OnAnyCircuitClosed(ICircuit circuit)
    {
        // Override in derived components
    }
}
