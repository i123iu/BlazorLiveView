@using BlazorLiveView.Core.Attributes
@using BlazorLiveView.Core.JSInterop
@inject ILiveViewJSRuntime JS

@attribute [LiveViewHideInMirror]

<script type="text/javascript">
    // https://stackoverflow.com/a/59173474

    window.addEventListener('beforeunload', function (event) {
        sessionStorage.removeItem('blazorLiveView.lock');
    });
    
    window.blazorLiveView = window.blazorLiveView || {};
    window.blazorLiveView.lockSessionStorage = function () {
        if (sessionStorage.getItem('blazorLiveView.lock')) {
            sessionStorage.clear();
            console.warn('Found a lock in session storage. The storage was cleared.');
        }

        sessionStorage.setItem('blazorLiveView.lock', '1');
    };
</script>

@code {
    [Parameter]
    public EventCallback<Guid> OnSessionIdRetrieved { get; set; }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        await LockSessionStorage();
        var sessionId = await RetrieveSessionId();
        if (sessionId == null || sessionId == Guid.Empty)
        {
            sessionId = Guid.NewGuid();
            await StoreSessionId(sessionId.Value);
        }
        await OnSessionIdRetrieved.InvokeAsync(sessionId.Value);
    }

    private async Task LockSessionStorage()
    {
        await JS.InvokeVoidAsyncNoMirror(
            "blazorLiveView.lockSessionStorage"
        );
    }

    private async Task<Guid?> RetrieveSessionId()
    {
        var sessionId = await JS.InvokeAsyncNoMirror<string>(
            "sessionStorage.getItem",
            new[] { "blazorLiveView.sessionId" }
        );
        return string.IsNullOrEmpty(sessionId)
            ? null
            : Guid.Parse(sessionId);
    }

    private async Task StoreSessionId(Guid sessionId)
    {
        await JS.InvokeVoidAsyncNoMirror(
            "sessionStorage.setItem",
            new[] { "blazorLiveView.sessionId", sessionId.ToString() }
        );
    }
}
