@using BlazorLiveView.Core.Attributes
@using BlazorLiveView.Core.Circuits
@using BlazorLiveView.Core.Circuits.Services
@using BlazorLiveView.Core.JSInterop
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop

@inject ICurrentCircuit currentCircuit
@inject ICircuitTracker circuitTracker
@inject ILiveViewJSRuntime jsRuntime
@inject ILogger<LiveViewMirrorSideTools> logger

<LaserPointerReceiver @ref="laserPointerReceiver" />
<LaserPointerTransmitter @ref="laserPointerTransmitter"
                         OnCursorMoved="@OnCursorMoved"
                         OnCursorLeft="@OnCursorLeft" />

@code {
    private IMirrorCircuit _mirrorCircuit = null!;
    private long _lastScrollTime = 0;
    private const long ScrollThrottleMs = 100;

    private LaserPointerReceiver? laserPointerReceiver;
    private LaserPointerTransmitter? laserPointerTransmitter;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (currentCircuit.Current is null)
        {
            logger.LogError("Component {ComponentName} must be used within a circuit",
                nameof(LiveViewMirrorSideTools)
            );
            return;
        }

        var thisCircuit = circuitTracker.GetCircuit(currentCircuit.Current.Id);
        if (thisCircuit is null)
        {
            logger.LogError("Component {ComponentName} could not find the current circuit",
                nameof(LiveViewMirrorSideTools)
            );
        }
        else if (thisCircuit is IUserCircuit)
        {
            logger.LogError("Component {ComponentName} cannot be used on a user circuit",
                nameof(LiveViewMirrorSideTools)
            );
        }
        else if (thisCircuit is IMirrorCircuit mirrorCircuit)
        {
            _mirrorCircuit = mirrorCircuit;
            _mirrorCircuit.ScrollSyncChanged += MirrorCircuit_ScrollSyncChanged;
            _mirrorCircuit.PointerSyncChanged += MirrorCircuit_PointerSyncChanged;
            _mirrorCircuit.SourceCircuit.WindowScrolled += SourceCircuit_WindowScrolled;
            _mirrorCircuit.SourceCircuit.UserCursorChanged += SourceCircuit_UserCursorMoved;
            if (_mirrorCircuit.SourceCircuit.ScrollPosition.HasValue)
            {
                SourceCircuit_WindowScrolled(_mirrorCircuit.SourceCircuit);
            }
            if (_mirrorCircuit.SourceCircuit.UserCursorPosition.HasValue)
            {
                var cursorPos = _mirrorCircuit.SourceCircuit.UserCursorPosition.Value;
                SourceCircuit_UserCursorMoved(_mirrorCircuit.SourceCircuit);
            }

            if (laserPointerTransmitter is not null && mirrorCircuit.PointerSyncEnabled)
            {
                await laserPointerTransmitter.StartCaptureCursor();
            }
        }
    }

    private void MirrorCircuit_ScrollSyncChanged(IMirrorCircuit mirrorCircuit)
    {
        _ = Scroll(mirrorCircuit.SourceCircuit);
        laserPointerReceiver?.HideAllPointers();
    }

    private void MirrorCircuit_PointerSyncChanged(IMirrorCircuit mirrorCircuit)
    {
        if (laserPointerTransmitter is null) return;
        if (mirrorCircuit.PointerSyncEnabled)
        {
            _ = laserPointerTransmitter.StartCaptureCursor();
        }
        else
        {
            _ = laserPointerTransmitter.StopCaptureCursor();
        }
    }

    private void SourceCircuit_WindowScrolled(IUserCircuit source)
    {
        _ = Scroll(source);
    }

    private ValueTask Scroll(IUserCircuit source)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (now - _lastScrollTime >= ScrollThrottleMs)
        {
            _lastScrollTime = now;
            if (_mirrorCircuit.ScrollSyncEnabled && source.ScrollPosition.HasValue)
            {
                return jsRuntime.InvokeVoidAsyncNoMirror(
                    "window.scrollTo",
                    source.ScrollPosition.Value.x,
                    source.ScrollPosition.Value.y
                );
            }
        }
        return ValueTask.CompletedTask;
    }

    private void SourceCircuit_UserCursorMoved(IUserCircuit source)
    {
        if (!_mirrorCircuit.ScrollSyncEnabled) return;

        if (source.UserCursorPosition.HasValue)
        {
            laserPointerReceiver?.ShowPointer(source.Id, source.UserCursorPosition.Value);
        }
        else
        {
            laserPointerReceiver?.HidePointer(source.Id);
        }
    }

    private void OnCursorMoved(Position pos)
    {
        _mirrorCircuit.NotifyMirrorCursorChanged(pos);
    }

    private void OnCursorLeft()
    {
        _mirrorCircuit.NotifyMirrorCursorChanged(null);
    }
}
