@using Microsoft.AspNetCore.Components.Web

@namespace BlazorLiveView.Core.Components.Tools

<div class="blv-permission-overlay" style="display: @(IsVisible ? "flex" : "none")">
    <div class="blv-permission-modal">
        <div class="blv-permission-header">
            <h2>Mirror Permission Request</h2>
        </div>
        
        <div class="blv-permission-body">
            <p>@Message</p>
        </div>
        
        <div class="blv-permission-footer">
            <button class="blv-btn blv-btn-deny"
                    @onclick="OnDenyClicked">
                Deny
            </button>
            <button class="blv-btn blv-btn-accept"
                    @onclick="OnAcceptClicked">
                Accept
            </button>
        </div>
    </div>
</div>

<style>
    .blv-permission-overlay {
        display: flex;
        justify-content: center;
        align-items: center;
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 10000;
    }

    .blv-permission-modal {
        background-color: white;
        border-radius: 8px;
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        max-width: 500px;
        width: 90%;
        overflow: hidden;
    }

    .blv-permission-header {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
        padding: 24px;
        margin: 0;
    }

    .blv-permission-header h2 {
        margin: 0;
        font-size: 20px;
        font-weight: 600;
    }

    .blv-permission-body {
        padding: 24px;
        color: #333;
        line-height: 1.6;
    }

    .blv-permission-body p {
        margin: 0;
        font-size: 16px;
    }

    .blv-permission-footer {
        display: flex;
        gap: 12px;
        padding: 16px 24px;
        background-color: #f8f9fa;
        justify-content: flex-end;
        border-top: 1px solid #e9ecef;
    }

    .blv-btn {
        padding: 10px 24px;
        border: none;
        border-radius: 4px;
        font-size: 14px;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.3s ease;
        min-width: 100px;
    }

    .blv-btn:hover {
        transform: translateY(-2px);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    }

    .blv-btn:active {
        transform: translateY(0);
    }

    .blv-btn-deny {
        background-color: #e9ecef;
        color: #495057;
    }

    .blv-btn-deny:hover {
        background-color: #dee2e6;
    }

    .blv-btn-accept {
        background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        color: white;
    }

    .blv-btn-accept:hover {
        background: linear-gradient(135deg, #5568d3 0%, #69388a 100%);
    }
</style>

@code {
    [Parameter]
    public bool IsVisible { get; set; }

    [Parameter]
    public string Message { get; set; } =
        "An administrator is requesting to view your screen.";

    [Parameter]
    public EventCallback OnAccept { get; set; }

    [Parameter]
    public EventCallback OnDeny { get; set; }

    private async Task OnAcceptClicked()
    {
        await OnAccept.InvokeAsync();
    }

    private async Task OnDenyClicked()
    {
        await OnDeny.InvokeAsync();
    }
}
