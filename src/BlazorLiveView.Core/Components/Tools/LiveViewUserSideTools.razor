@using BlazorLiveView.Core.Attributes
@using BlazorLiveView.Core.Circuits
@using BlazorLiveView.Core.Circuits.Services
@using BlazorLiveView.Core.JSInterop
@using BlazorLiveView.Core.Options
@using Microsoft.Extensions.Logging
@using Microsoft.JSInterop

@attribute [LiveViewTranslateToAttribute(typeof(LiveViewMirrorSideTools))]

@inject ICurrentCircuit currentCircuit
@inject ILiveViewJSRuntime jsRuntime
@inject ICircuitTracker circuitTracker
@inject ILogger<LiveViewUserSideTools> logger
@inject LiveViewOptions options

<script type="text/javascript">
    window.blazorLiveView = window.blazorLiveView || {};
    window.blazorLiveView.screen = window.blazorLiveView.screen || {};

    window.blazorLiveView.screen.addResizeEvent = function (dotNetRef, throttleMs) {
        let lastResizeTime = 0;
        
        const throttledResize = function () {
            const now = Date.now();
            if (now - lastResizeTime >= throttleMs) {
                lastResizeTime = now;
                dotNetRef.invokeMethodAsync("WindowSizeChanged", window.innerWidth, window.innerHeight);
            }
        };
        
        window.addEventListener("resize", throttledResize);
        // Invoke once to set the initial size.
        throttledResize();
    }

    window.blazorLiveView.screen.addScrollEvent = function (dotNetRef, throttleMs) {
        let lastScrollTime = 0;
        
        const throttledScroll = function () {
            const now = Date.now();
            if (now - lastScrollTime >= throttleMs) {
                lastScrollTime = now;
                dotNetRef.invokeMethodAsync("WindowScrolled", window.scrollX, window.scrollY);
            }
        };
        
        window.addEventListener("scroll", throttledScroll);
        // Invoke once to set the initial scroll position.
        throttledScroll();
    }
</script>

<LaserPointerReceiver @ref="laserPointerReceiver" />
<LaserPointerTransmitter @ref="laserPointerTransmitter"
                         OnCursorMoved="@OnCursorMoved"
                         OnCursorLeft="@OnCursorLeft" />

@code {
    private LaserPointerReceiver? laserPointerReceiver;
    private LaserPointerTransmitter? laserPointerTransmitter;

    private DotNetObjectReference<LiveViewUserSideTools>? _dotNetRef;
    private long _lastWindowSizeChangedTime = 0;
    private long _lastWindowScrolledTime = 0;
    private IUserCircuit _userCircuit = null!;

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await jsRuntime.InvokeVoidAsyncNoMirror(
                "blazorLiveView.screen.addResizeEvent",
                _dotNetRef,
                options.ToolsUpdateIntervalMs
            );
            await jsRuntime.InvokeVoidAsyncNoMirror(
                "blazorLiveView.screen.addScrollEvent",
                _dotNetRef,
                options.ToolsUpdateIntervalMs
            );

            var circuit = circuitTracker.GetCircuit(currentCircuit.Current!.Id);
            if (circuit is null)
            {
                logger.LogError("Component {ComponentName} could not find the current circuit",
                    nameof(LiveViewMirrorSideTools)
                );
            }
            else if (circuit is IMirrorCircuit)
            {

                logger.LogError("Component {ComponentName} cannot be used on a user circuit",
                    nameof(LiveViewMirrorSideTools)
                );
            }
            else if (circuit is IUserCircuit userCircuit)
            {
                _userCircuit = userCircuit;
                _userCircuit.MirrorCursorChanged += MirrorCursorChanged;
            }

            // Start capturing user cursor
            if (laserPointerTransmitter is not null)
            {
                await laserPointerTransmitter.StartCaptureCursor();
            }
        }
    }

    [JSInvokable]
    public void WindowSizeChanged(int width, int height)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (now - _lastWindowSizeChangedTime >= options.ToolsUpdateIntervalMs)
        {
            _lastWindowSizeChangedTime = now;
            currentCircuit.AsUserCircuit()?
                .NotifyWindowResized(new(width, height));
        }
    }

    [JSInvokable]
    public void WindowScrolled(int scrollX, int scrollY)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (now - _lastWindowScrolledTime >= options.ToolsUpdateIntervalMs)
        {
            _lastWindowScrolledTime = now;
            currentCircuit.AsUserCircuit()?
                .NotifyWindowScrolled(new(scrollX, scrollY));
        }
    }

    private void MirrorCursorChanged(IUserCircuit userCircuit, string identifier)
    {
        var mirrorCursorPositions = userCircuit.MirrorCursorPositions;
        if (mirrorCursorPositions.TryGetValue(identifier, out Position pos))
        {
            laserPointerReceiver?.ShowPointer(identifier, pos);
        }
        else
        {
            laserPointerReceiver?.HidePointer(identifier);
        }
    }

    private void OnCursorMoved(Position pos)
    {
        currentCircuit.AsUserCircuit()?
            .NotifyUserCursorChanged(pos);
    }

    private void OnCursorLeft()
    {
        currentCircuit.AsUserCircuit()?
            .NotifyUserCursorChanged(null);
    }
}
