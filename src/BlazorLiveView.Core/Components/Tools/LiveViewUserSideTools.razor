@using BlazorLiveView.Core.Attributes
@using BlazorLiveView.Core.Circuits
@using BlazorLiveView.Core.Circuits.Services
@using BlazorLiveView.Core.JSInterop
@using Microsoft.JSInterop

@attribute [LiveViewTranslateToAttribute(typeof(LiveViewMirrorSideTools))]

@inject ICurrentCircuit currentCircuit
@inject ILiveViewJSRuntime jsRuntime

<script type="text/javascript">
    window.blazorLiveView_addResizeEvent = function(dotNetRef) {
        let lastResizeTime = 0;
        const resizeThrottleMs = 100; // Max 10 calls per second
        
        const throttledResize = function() {
            const now = Date.now();
            if (now - lastResizeTime >= resizeThrottleMs) {
                lastResizeTime = now;
                dotNetRef.invokeMethodAsync("WindowSizeChanged", window.innerWidth, window.innerHeight);
            }
        };
        
        window.addEventListener("resize", throttledResize);
        // Invoke once to set the initial size.
        throttledResize();
    }

    window.blazorLiveView_addScrollEvent = function(dotNetRef) {
        let lastScrollTime = 0;
        const scrollThrottleMs = 100; // Max 10 calls per second
        
        const throttledScroll = function() {
            const now = Date.now();
            if (now - lastScrollTime >= scrollThrottleMs) {
                lastScrollTime = now;
                dotNetRef.invokeMethodAsync("WindowScrolled", window.scrollX, window.scrollY);
            }
        };
        
        window.addEventListener("scroll", throttledScroll);
        // Invoke once to set the initial scroll position.
        throttledScroll();
    }

    // Pointer management
    const pointers = {};
    const pointerColors = {};
    const pointerLastUpdateTime = {};
    const pointerStaleTimeoutMs = 5000;

    window.blazorLiveView_getPointerColor = function(pointerId) {
        if (!pointerColors[pointerId]) {
            // Generate a consistent color based on pointerId hash
            let hash = 0;
            for (let i = 0; i < pointerId.length; i++) {
                hash = ((hash << 5) - hash) + pointerId.charCodeAt(i);
                hash = hash & hash; // Convert to 32bit integer
            }
            const hue = Math.abs(hash) % 360;
            pointerColors[pointerId] = `hsl(${hue}, 70%, 50%)`;
        }
        return pointerColors[pointerId];
    };

    window.blazorLiveView_cleanupStalePointers = function() {
        const now = Date.now();
        const stalePointerIds = [];
        
        for (const pointerId in pointerLastUpdateTime) {
            if (now - pointerLastUpdateTime[pointerId] >= pointerStaleTimeoutMs) {
                stalePointerIds.push(pointerId);
            }
        }
        
        stalePointerIds.forEach(pointerId => {
            const pointer = pointers[pointerId];
            if (pointer) {
                pointer.style.display = 'none';
                delete pointers[pointerId];
                delete pointerLastUpdateTime[pointerId];
            }
        });
    };

    window.blazorLiveView_showPointer = function(pointerId, x, y) {
        let pointer = pointers[pointerId];
        if (!pointer) {
            pointer = document.createElement('div');
            pointer.id = `pointer-${pointerId}`;
            pointer.style.position = 'fixed';
            pointer.style.width = '24px';
            pointer.style.height = '24px';
            pointer.style.borderRadius = '50%';
            pointer.style.pointerEvents = 'none';
            pointer.style.zIndex = '10000';
            pointer.style.opacity = '0.7';
            pointer.style.border = '2px solid rgba(255, 255, 255, 0.8)';
            document.body.appendChild(pointer);
            pointers[pointerId] = pointer;
        }
        
        pointerLastUpdateTime[pointerId] = Date.now();
        const color = window.blazorLiveView_getPointerColor(pointerId);
        pointer.style.backgroundColor = color;
        pointer.style.left = (x - 12) + 'px';
        pointer.style.top = (y - 12) + 'px';
        pointer.style.display = 'block';
        
        window.blazorLiveView_cleanupStalePointers();
    };

    window.blazorLiveView_hidePointer = function(pointerId) {
        const pointer = pointers[pointerId];
        if (pointer) {
            pointer.style.display = 'none';
            delete pointers[pointerId];
            delete pointerLastUpdateTime[pointerId];
        }
        
        window.blazorLiveView_cleanupStalePointers();
    };
</script>

@code {
    private DotNetObjectReference<LiveViewUserSideTools>? _dotNetRef;
    private long _lastWindowSizeChangedTime = 0;
    private long _lastWindowScrolledTime = 0;
    private const long WindowSizeChangedThrottleMs = 100; // Max 10 calls per second
    private const long WindowScrolledThrottleMs = 100; // Max 10 calls per second

    protected override async Task OnInitializedAsync()
    {
        _dotNetRef = DotNetObjectReference.Create(this);
    }

    public void Dispose()
    {
        _dotNetRef?.Dispose();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await jsRuntime.InvokeVoidAsyncNoMirror("blazorLiveView_addResizeEvent", _dotNetRef);
            await jsRuntime.InvokeVoidAsyncNoMirror("blazorLiveView_addScrollEvent", _dotNetRef);
            
            var userCircuit = currentCircuit.AsUserCircuit();
            if (userCircuit is not null)
            {
                userCircuit.PointerShown += OnPointerShown;
                userCircuit.PointerHidden += OnPointerHidden;
            }
        }
    }

    [JSInvokable]
    public void WindowSizeChanged(int width, int height)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (now - _lastWindowSizeChangedTime >= WindowSizeChangedThrottleMs)
        {
            _lastWindowSizeChangedTime = now;
            currentCircuit.AsUserCircuit()?
                .NotifyWindowResized(width, height);
        }
    }

    [JSInvokable]
    public void WindowScrolled(int scrollX, int scrollY)
    {
        var now = DateTimeOffset.UtcNow.ToUnixTimeMilliseconds();
        if (now - _lastWindowScrolledTime >= WindowScrolledThrottleMs)
        {
            _lastWindowScrolledTime = now;
            currentCircuit.AsUserCircuit()?
                .NotifyWindowScrolled(scrollX, scrollY);
        }
    }

    private async void OnPointerShown(IUserCircuit circuit, string pointerId, int x, int y)
    {
        await jsRuntime.InvokeVoidAsyncNoMirror("blazorLiveView_showPointer", pointerId, x, y);
    }

    private async void OnPointerHidden(IUserCircuit circuit, string pointerId)
    {
        await jsRuntime.InvokeVoidAsyncNoMirror("blazorLiveView_hidePointer", pointerId);
    }
}
